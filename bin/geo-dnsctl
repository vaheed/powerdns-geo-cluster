#!/usr/bin/env python3
import argparse
import csv
import ipaddress
import json
import os
import pathlib
import sys
import urllib.error
import urllib.parse
import urllib.request

ROOT = pathlib.Path(__file__).resolve().parents[1]
ALLOWED_TYPES = {"A", "AAAA", "CNAME", "TXT", "MX", "NS", "SRV", "CAA", "PTR", "LUA"}

def load_env_file(path):
    if not path.exists():
        return
    for line in path.read_text().splitlines():
        line = line.strip()
        if not line or line.startswith("#") or "=" not in line:
            continue
        k, v = line.split("=", 1)
        os.environ.setdefault(k.strip(), v.strip().strip('"').strip("'"))

def load_env():
    load_env_file(ROOT / ".env")
    loc = os.environ.get("LOCATION_NAME", "eu-ams")
    load_env_file(ROOT / "config" / "locations" / f"{loc}.env")

load_env()
API_BASE = os.environ.get("PDNS_API_URL", "http://127.0.0.1:8081/api/v1/servers/localhost").rstrip("/")
API_KEY = os.environ.get("PDNS_API_KEY", "")


def req(method, path, body=None, ok=(200, 201, 204)):
    if not API_KEY:
        raise SystemExit("PDNS_API_KEY is not set")
    data = None
    headers = {"X-API-Key": API_KEY, "Accept": "application/json"}
    if body is not None:
        data = json.dumps(body).encode()
        headers["Content-Type"] = "application/json"
    r = urllib.request.Request(API_BASE + path, data=data, headers=headers, method=method)
    try:
        with urllib.request.urlopen(r, timeout=15) as resp:
            raw = resp.read().decode()
            if resp.status not in ok:
                raise SystemExit(f"{method} {path} failed: HTTP {resp.status}: {raw}")
            return json.loads(raw) if raw else None
    except urllib.error.HTTPError as e:
        raise SystemExit(f"{method} {path} failed: HTTP {e.code}: {e.read().decode(errors='replace')}")

def fqdn(name, domain=None):
    n = (name or "").strip().strip(".")
    d = (domain or "").strip().strip(".")
    if n in ("", "@"):
        return f"{d}." if d else "."
    if d and (n == d or n.endswith("." + d)):
        return f"{n}."
    return f"{n}.{d}." if d else f"{n}."

def zone_id(domain):
    return urllib.parse.quote(domain.rstrip(".") + ".", safe="")

def validate_rrtype(rrtype):
    t = rrtype.upper()
    if t not in ALLOWED_TYPES:
        raise SystemExit(f"unsupported RR type: {rrtype}")
    return t

def validate_value(rrtype, value):
    rrtype = rrtype.upper()
    if rrtype in ("A", "AAAA"):
        ipaddress.ip_address(value)

def add_record(args):
    domain = args.domain.rstrip(".") + "."
    rrtype = validate_rrtype(args.type)
    validate_value(rrtype, args.value)
    rr = {"name": fqdn(args.name, domain), "type": rrtype, "ttl": int(args.ttl), "changetype": "REPLACE", "records": [{"content": args.value, "disabled": False}]}
    req("PATCH", f"/zones/{zone_id(domain)}", {"rrsets": [rr]}, ok=(204,))
    print("ok")

def add_geo_record(args):
    for v in (args.eu, args.na, args.asia, args.default):
        ipaddress.ip_address(v)
    domain = args.domain.rstrip(".") + "."
    name = fqdn(args.name, domain)
    lua = ("A \";if continent('EU') then return '%s' elseif continent('NA') then return '%s' elseif continent('AS') then return '%s' else return '%s' end\"") % (args.eu, args.na, args.asia, args.default)
    rr = {"name": name, "type": "LUA", "ttl": int(args.ttl), "changetype": "REPLACE", "records": [{"content": lua, "disabled": False}]}
    req("PATCH", f"/zones/{zone_id(domain)}", {"rrsets": [rr]}, ok=(204,))
    print("ok")

def billing_summary(args):
    import requests
    u = f"{args.api.rstrip('/')}/api/v1/billing/summary?account={args.account}&month={args.month}"
    print(requests.get(u, timeout=15).text)

def billing_zones(args):
    import requests
    u = f"{args.api.rstrip('/')}/api/v1/billing/zones?account={args.account}"
    print(requests.get(u, timeout=15).text)

def billing_export(args):
    import requests
    u = f"{args.api.rstrip('/')}/api/v1/billing/report?account={args.account}&month={args.month}&format={args.format}"
    print(requests.get(u, timeout=15).text)

def billing_set_tier(args):
    import psycopg2
    conn = psycopg2.connect(dbname=os.getenv("POSTGRES_DB", "pdns"), user=os.getenv("POSTGRES_USER", "pdns"), password=os.getenv("POSTGRES_PASSWORD", ""), host=os.getenv("POSTGRES_HOST", "127.0.0.1"))
    conn.autocommit = True
    with conn.cursor() as cur:
        cur.execute("INSERT INTO billing_zone_meta(zone, tier) VALUES (%s,%s)", (args.zone.rstrip(".")+".", args.tier))
        cur.execute("INSERT INTO billing_events(event_type, location, zone, metric_name, metric_value, meta) VALUES ('tier_change', %s, %s, 'tier', 1, %s::jsonb)", (os.getenv("LOCATION_NAME", "unknown"), args.zone.rstrip(".")+".", json.dumps({"tier": args.tier})))
    print("ok")

def main():
    p = argparse.ArgumentParser(prog="geo-dnsctl")
    sub = p.add_subparsers(dest="cmd", required=True)
    s = sub.add_parser("add-record"); s.add_argument("domain"); s.add_argument("name"); s.add_argument("type"); s.add_argument("value"); s.add_argument("--ttl", default=300); s.set_defaults(func=add_record)
    s = sub.add_parser("add-geo-record"); s.add_argument("domain"); s.add_argument("name"); s.add_argument("--eu", required=True); s.add_argument("--na", required=True); s.add_argument("--asia", required=True); s.add_argument("--default", required=True); s.add_argument("--ttl", default=60); s.set_defaults(func=add_geo_record)

    b = sub.add_parser("billing")
    bb = b.add_subparsers(dest="billing_cmd", required=True)
    s = bb.add_parser("summary"); s.add_argument("--account", required=True); s.add_argument("--month", required=True); s.add_argument("--api", default="http://127.0.0.1:8088"); s.set_defaults(func=billing_summary)
    s = bb.add_parser("zones"); s.add_argument("--account", required=True); s.add_argument("--api", default="http://127.0.0.1:8088"); s.set_defaults(func=billing_zones)
    s = bb.add_parser("export"); s.add_argument("--account", required=True); s.add_argument("--month", required=True); s.add_argument("--format", default="csv"); s.add_argument("--api", default="http://127.0.0.1:8088"); s.set_defaults(func=billing_export)
    s = bb.add_parser("set-tier"); s.add_argument("zone"); s.add_argument("tier", choices=["standard", "geo", "geo-dnssec"]); s.set_defaults(func=billing_set_tier)

    args = p.parse_args()
    rc = args.func(args)
    if isinstance(rc, int):
        sys.exit(rc)

if __name__ == "__main__":
    main()
